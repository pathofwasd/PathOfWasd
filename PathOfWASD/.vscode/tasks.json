{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build PathOfWASD",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/PathOfWASD.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "DOTNET_CLI_HOME": "${workspaceFolder}\\.dotnet-cli",
          "DOTNET_SKIP_FIRST_TIME_EXPERIENCE": "1",
          "DOTNET_NOLOGO": "1"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run PathOfWASD",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/PathOfWASD.csproj"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "DOTNET_CLI_HOME": "${workspaceFolder}\\.dotnet-cli",
          "DOTNET_SKIP_FIRST_TIME_EXPERIENCE": "1",
          "DOTNET_NOLOGO": "1"
        }
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "publish PathOfWASD single-file exe",
      "type": "process",
      "command": "dotnet",
      "args": [
        "publish",
        "${workspaceFolder}/PathOfWASD.csproj",
        "-p:PublishProfile=${workspaceFolder}/Properties/PublishProfiles/SingleFile-win-x64.pubxml"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "DOTNET_CLI_HOME": "${workspaceFolder}\\.dotnet-cli",
          "DOTNET_SKIP_FIRST_TIME_EXPERIENCE": "1",
          "DOTNET_NOLOGO": "1"
        }
      },
      "problemMatcher": "$msCompile"
    }
  ]
}
